# FullStackArkham Gateway Configuration

# Server
SERVER_HOST=0.0.0.0
SERVER_PORT=8080
LOG_LEVEL=info

# Database
DATABASE_HOST=postgres
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=fullstackarkham
DATABASE_SSL_MODE=disable

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Arkham Security
ARKHAM_ENABLED=true
ARKHAM_ENDPOINT=http://arkham:8081

# JWT Secret (change in production!)
JWT_SECRET=fullstackarkham-dev-secret-change-in-production

# Model API Keys (Optional - leave empty to use local provider)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Default to local provider for testing
DEFAULT_MODEL_TIER=local
