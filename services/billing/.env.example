# Billing Service Environment Variables

# ==================== DOMAIN ====================
APP_DOMAIN=stelar.host

# ==================== STRIPE API KEYS ====================
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_YOUR_KEY_HERE
STRIPE_WEBHOOK_SECRET=whsec_YOUR_SECRET_HERE

# ==================== STRIPE PRICE IDs ====================
# Get from: https://dashboard.stripe.com/products
# Note: Use the base price ID - yearly discount is configured in Stripe as upsell

STRIPE_PRICE_ID_BASIC=price_YOUR_BASIC_PRICE_ID
STRIPE_PRICE_ID_PRO=price_YOUR_PRO_PRICE_ID
STRIPE_PRICE_ID_ENTERPRISE=price_YOUR_ENTERPRISE_PRICE_ID

# ==================== STRIPE CONFIGURATION ====================
STRIPE_CURRENCY=usd

# ==================== DATABASE ====================
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/fullstackarkham

# ==================== SERVICE ====================
LOG_LEVEL=info
